---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mona Mayhem - GitHub Contribution Battle Arena</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Space+Grotesk:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>
		<style>
			:root {
				--bg: #0a0a1a;
				--panel: rgba(15, 18, 41, 0.9);
				--panel-border: rgba(95, 237, 131, 0.35);
				--green: #5fed83;
				--purple: #8a2be2;
				--text: #e8ebff;
				--muted: #9ca3cf;
				--danger: #ff3366;
				--success: #5fed83;
				--scanline-opacity: 0.16;
				font-family: 'Space Grotesk', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
			}

			body {
				margin: 0;
				padding: 1.25rem;
				background: var(--bg);
				color: var(--text);
				position: relative;
				min-height: 100vh;
			}

			body::before,
			body::after {
				content: '';
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 0;
			}

			body::before {
				background: repeating-linear-gradient(
					to bottom,
					rgba(255, 255, 255, 0) 0,
					rgba(255, 255, 255, 0) 2px,
					rgba(255, 255, 255, 0.12) 3px,
					rgba(255, 255, 255, 0) 4px
				);
				opacity: var(--scanline-opacity);
			}

			body::after {
				background:
					radial-gradient(circle at 15% 20%, rgba(95, 237, 131, 0.2), transparent 38%),
					radial-gradient(circle at 85% 75%, rgba(138, 43, 226, 0.2), transparent 42%),
					radial-gradient(circle at center, transparent 35%, rgba(0, 0, 0, 0.45) 100%);
			}

			main {
				max-width: 1040px;
				margin: 0 auto;
				position: relative;
				z-index: 1;
			}

			h1 {
				margin: 0;
				line-height: 1.3;
				font-family: 'Press Start 2P', cursive;
				font-size: clamp(1.2rem, 3.5vw, 1.8rem);
				color: var(--green);
				text-transform: uppercase;
				text-shadow:
					0 0 8px rgba(95, 237, 131, 0.8),
					0 0 18px rgba(95, 237, 131, 0.5),
					0 0 24px rgba(138, 43, 226, 0.35);
				animation: neonPulse 2.8s ease-in-out infinite;
			}

			.subtitle {
				margin-top: 0.5rem;
				margin-bottom: 1.25rem;
				color: var(--muted);
				font-size: 0.95rem;
			}

			.battle-form {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.9rem;
				padding: 1rem;
				border: 1px solid var(--panel-border);
				border-radius: 0.5rem;
				background: var(--panel);
				box-shadow:
					0 0 0 1px rgba(95, 237, 131, 0.12),
					0 12px 24px rgba(0, 0, 0, 0.45);
			}

			.field-group {
				animation: floatIn 0.8s ease both;
			}

			.field-group:nth-of-type(2) {
				animation-delay: 0.1s;
			}

			.field-group.invalid {
				animation: shakeError 0.35s ease;
			}

			label {
				display: block;
				font-family: 'Press Start 2P', cursive;
				font-size: 0.62rem;
				letter-spacing: 0.04em;
				color: var(--green);
				margin-bottom: 0.35rem;
			}

			input {
				width: 100%;
				padding: 0.65rem 0.75rem;
				border: 1px solid rgba(138, 43, 226, 0.5);
				border-radius: 0.4rem;
				font-size: 1rem;
				background: rgba(8, 10, 30, 0.9);
				color: var(--text);
				box-sizing: border-box;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}

			input:focus {
				outline: none;
				border-color: var(--green);
				box-shadow:
					0 0 0 2px rgba(95, 237, 131, 0.25),
					0 0 12px rgba(95, 237, 131, 0.35);
			}

			.field-group.invalid input,
			input[aria-invalid='true'] {
				border-color: var(--danger);
				box-shadow:
					0 0 0 2px rgba(255, 51, 102, 0.26),
					0 0 14px rgba(255, 51, 102, 0.42);
			}

			.field-error {
				margin: 0.38rem 0 0;
				min-height: 1.1rem;
				font-size: 0.82rem;
				color: var(--danger);
				text-shadow: 0 0 8px rgba(255, 51, 102, 0.45);
			}

			button {
				grid-column: 1 / -1;
				padding: 0.75rem 1rem;
				border: 0;
				border-radius: 0.4rem;
				background: linear-gradient(120deg, var(--green), var(--purple));
				color: #071014;
				font-family: 'Press Start 2P', cursive;
				font-weight: 700;
				font-size: 0.68rem;
				cursor: pointer;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				animation: floatIn 0.8s ease both 0.2s;
				transition: transform 0.18s ease, box-shadow 0.2s ease;
			}

			button:hover {
				transform: translateY(-1px);
				box-shadow:
					0 0 14px rgba(95, 237, 131, 0.45),
					0 0 20px rgba(138, 43, 226, 0.35);
			}

			button:focus-visible {
				outline: 2px solid var(--green);
				outline-offset: 2px;
				box-shadow:
					0 0 0 4px rgba(95, 237, 131, 0.22),
					0 0 14px rgba(138, 43, 226, 0.3);
			}

			button:disabled {
				opacity: 0.8;
				cursor: not-allowed;
				transform: none;
				box-shadow: none;
			}

			.status {
				margin-top: 1rem;
				min-height: 1.5rem;
				font-weight: 700;
				letter-spacing: 0.01em;
				color: var(--muted);
			}

			.status.loading {
				animation: loadingShift 1.1s ease-in-out infinite alternate;
			}

			.status.error {
				color: var(--danger);
				text-shadow: 0 0 10px rgba(255, 51, 102, 0.55);
			}

			.status.error.shake {
				animation: shakeError 0.35s ease;
			}

			.status.success {
				color: var(--success);
			}

			.results {
				margin-top: 1rem;
				padding: 1rem;
				border: 1px solid var(--panel-border);
				border-radius: 0.5rem;
				background: var(--panel);
				box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);
			}

			.results h2 {
				margin-top: 0;
				margin-bottom: 0.75rem;
				font-family: 'Press Start 2P', cursive;
				font-size: 0.85rem;
				color: var(--green);
				text-shadow: 0 0 8px rgba(95, 237, 131, 0.4);
			}

			.summary {
				font-weight: 700;
				margin-bottom: 0.85rem;
				color: var(--text);
			}

			.battle-stage {
				display: grid;
				gap: 0.8rem;
				align-items: start;
			}

			.vs-badge {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 3rem;
				height: 3rem;
				margin: 0 auto;
				border-radius: 999px;
				font-family: 'Press Start 2P', cursive;
				font-size: 0.72rem;
				color: #f8f9ff;
				background: linear-gradient(140deg, var(--green), var(--purple), var(--green));
				background-size: 250% 250%;
				box-shadow:
					0 0 12px rgba(95, 237, 131, 0.4),
					0 0 20px rgba(138, 43, 226, 0.35);
				animation: vsShift 3.4s linear infinite;
			}

			.players {
				display: grid;
				gap: 0.75rem;
			}

			.player {
				position: relative;
				overflow: hidden;
				padding: 0.75rem;
				border: 1px solid rgba(138, 43, 226, 0.45);
				border-radius: 0.45rem;
				background: rgba(9, 12, 34, 0.92);
				box-shadow:
					0 0 0 1px rgba(95, 237, 131, 0.08),
					0 8px 16px rgba(0, 0, 0, 0.3);
			}

			.player::after {
				content: '';
				position: absolute;
				inset: -140% -25%;
				background: linear-gradient(115deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0));
				transform: translateX(-130%) rotate(15deg);
				animation: shimmerSweep 4.8s ease-in-out infinite;
				pointer-events: none;
			}

			.player h3 {
				margin-top: 0;
				margin-bottom: 0.35rem;
				font-family: 'Press Start 2P', cursive;
				font-size: 0.68rem;
				color: var(--green);
				line-height: 1.45;
			}

			.meta {
				margin-bottom: 0.75rem;
			}

			.meta p {
				margin: 0.22rem 0;
				color: var(--text);
			}

			.player p {
				margin: 0.2rem 0;
				position: relative;
				z-index: 1;
			}

			.contribution-graph {
				display: flex;
				gap: 2px;
				overflow-x: auto;
				padding-bottom: 2px;
				position: relative;
				z-index: 1;
			}

			.week-column {
				display: grid;
				grid-template-rows: repeat(7, 8px);
				gap: 2px;
			}

			.day-cell {
				width: 8px;
				height: 8px;
				border-radius: 2px;
				transition: transform 0.14s ease, box-shadow 0.14s ease;
			}

			.day-cell:hover {
				transform: scale(1.3);
				box-shadow:
					0 0 8px rgba(95, 237, 131, 0.6),
					0 0 12px rgba(138, 43, 226, 0.4);
			}

			.note {
				font-size: 0.9rem;
				color: var(--muted);
			}

			@keyframes neonPulse {
				0%,
				100% {
					opacity: 1;
					text-shadow:
						0 0 8px rgba(95, 237, 131, 0.8),
						0 0 18px rgba(95, 237, 131, 0.5),
						0 0 24px rgba(138, 43, 226, 0.35);
				}
				50% {
					opacity: 0.9;
					text-shadow:
						0 0 6px rgba(95, 237, 131, 0.65),
						0 0 14px rgba(95, 237, 131, 0.45),
						0 0 30px rgba(138, 43, 226, 0.5);
				}
			}

			@keyframes vsShift {
				0% {
					background-position: 0% 50%;
				}
				100% {
					background-position: 100% 50%;
				}
			}

			@keyframes shimmerSweep {
				0% {
					transform: translateX(-130%) rotate(15deg);
				}
				60%,
				100% {
					transform: translateX(130%) rotate(15deg);
				}
			}

			@keyframes floatIn {
				from {
					opacity: 0;
					transform: translateY(10px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes loadingShift {
				0% {
					color: var(--green);
					text-shadow: 0 0 8px rgba(95, 237, 131, 0.45);
				}
				100% {
					color: var(--purple);
					text-shadow: 0 0 8px rgba(138, 43, 226, 0.45);
				}
			}

			@keyframes shakeError {
				0%,
				100% {
					transform: translateX(0);
				}
				20% {
					transform: translateX(-4px);
				}
				40% {
					transform: translateX(4px);
				}
				60% {
					transform: translateX(-3px);
				}
				80% {
					transform: translateX(3px);
				}
			}

			@media (min-width: 1025px) {
				.battle-stage {
					grid-template-columns: 1fr auto 1fr;
				}

				.players {
					grid-template-columns: 1fr 1fr;
				}
			}

			@media (max-width: 1024px) {
				.battle-stage {
					grid-template-columns: 1fr;
				}

				.vs-badge {
					order: -1;
				}
			}

			@media (max-width: 768px) {
				body {
					padding: 0.85rem;
				}

				h1 {
					font-size: 1.05rem;
				}

				.subtitle {
					font-size: 0.86rem;
				}

				.battle-form {
					grid-template-columns: 1fr;
					padding: 0.85rem;
					gap: 0.75rem;
				}

				label {
					font-size: 0.55rem;
				}

				input {
					font-size: 0.95rem;
				}

				button {
					font-size: 0.58rem;
					padding: 0.7rem 0.8rem;
				}

				.results {
					padding: 0.85rem;
				}

				.results h2 {
					font-size: 0.72rem;
				}

				.player h3 {
					font-size: 0.58rem;
				}

				.meta p,
				.player p,
				.status,
				.note {
					font-size: 0.9rem;
				}

				.day-cell {
					width: 7px;
					height: 7px;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				* {
					animation: none !important;
					transition: none !important;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<h1>Mona Mayhem</h1>
			<p class="subtitle">GitHub Contribution Battle Arena</p>

			<form id="battleForm" class="battle-form">
				<div class="field-group">
					<label for="playerOne">Player 1 Username</label>
					<input
						id="playerOne"
						name="playerOne"
						type="text"
						autocomplete="off"
						autocapitalize="none"
						spellcheck="false"
						enterkeyhint="go"
						aria-describedby="playerOneError"
						required
					/>
					<p id="playerOneError" class="field-error" aria-live="polite"></p>
				</div>
				<div class="field-group">
					<label for="playerTwo">Player 2 Username</label>
					<input
						id="playerTwo"
						name="playerTwo"
						type="text"
						autocomplete="off"
						autocapitalize="none"
						spellcheck="false"
						enterkeyhint="go"
						aria-describedby="playerTwoError"
						required
					/>
					<p id="playerTwoError" class="field-error" aria-live="polite"></p>
				</div>
				<button id="battleButton" type="submit">Battle</button>
			</form>

			<p id="statusMessage" class="status" aria-live="polite"></p>

			<section id="results" class="results" hidden>
				<h2>Battle Results</h2>
				<p id="battleSummary" class="summary"></p>
				<div class="battle-stage">
					<div id="playerOneSlot"></div>
					<div class="vs-badge" aria-label="Versus">VS</div>
					<div id="playerTwoSlot"></div>
				</div>
			</section>
		</main>

		<script>
			const USERNAME_PATTERN = /^[A-Za-z0-9-]{1,39}$/;
			const DEFAULT_COLORS = ['#ebedf0', '#9be9a8', '#40c463', '#30a14e', '#216e39'];

			const form = document.getElementById('battleForm');
			const playerOneInput = document.getElementById('playerOne');
			const playerTwoInput = document.getElementById('playerTwo');
			const playerOneError = document.getElementById('playerOneError');
			const playerTwoError = document.getElementById('playerTwoError');
			const battleButton = document.getElementById('battleButton');
			const statusMessage = document.getElementById('statusMessage');
			const resultsSection = document.getElementById('results');
			const battleSummary = document.getElementById('battleSummary');
			const playerOneSlot = document.getElementById('playerOneSlot');
			const playerTwoSlot = document.getElementById('playerTwoSlot');

			function setFieldError(input, errorElement, message) {
				const group = input.closest('.field-group');
				errorElement.textContent = message;
				input.setAttribute('aria-invalid', 'true');
				if (group) {
					group.classList.add('invalid');
				}
			}

			function clearFieldError(input, errorElement) {
				const group = input.closest('.field-group');
				errorElement.textContent = '';
				input.removeAttribute('aria-invalid');
				if (group) {
					group.classList.remove('invalid');
				}
			}

			function clearAllFieldErrors() {
				clearFieldError(playerOneInput, playerOneError);
				clearFieldError(playerTwoInput, playerTwoError);
			}

			function setStatus(message, type) {
				statusMessage.textContent = message;
				statusMessage.className = type ? `status ${type}` : 'status';
				if (type === 'error') {
					statusMessage.classList.remove('shake');
					void statusMessage.offsetWidth;
					statusMessage.classList.add('shake');
				}
			}

			function clearResults() {
				battleSummary.textContent = '';
				playerOneSlot.innerHTML = '';
				playerTwoSlot.innerHTML = '';
				resultsSection.hidden = true;
			}

			function isValidUsername(username) {
				if (!USERNAME_PATTERN.test(username)) {
					return false;
				}

				if (username.startsWith('-') || username.endsWith('-')) {
					return false;
				}

				return true;
			}

			function readNumberFromRecord(record, keys) {
				for (const key of keys) {
					const value = record[key];
					if (typeof value === 'number' && Number.isFinite(value)) {
						return value;
					}
				}

				return undefined;
			}

			function getContributionDays(week) {
				if (Array.isArray(week.contribution_days)) {
					return week.contribution_days;
				}

				if (Array.isArray(week.contributionDays)) {
					return week.contributionDays;
				}

				return [];
			}

			function dayCount(day) {
				return readNumberFromRecord(day ?? {}, ['count', 'contributionCount', 'contributions']) ?? 0;
			}

			function dayLevel(day) {
				const explicitLevel = readNumberFromRecord(day ?? {}, ['level']);
				if (typeof explicitLevel === 'number') {
					return Math.max(0, Math.min(4, Math.round(explicitLevel)));
				}

				const count = dayCount(day);
				if (count === 0) {
					return 0;
				}
				if (count < 3) {
					return 1;
				}
				if (count < 6) {
					return 2;
				}
				if (count < 10) {
					return 3;
				}
				return 4;
			}

			function extractDailyCounts(source) {
				const counts = [];

				if (!source || typeof source !== 'object') {
					return counts;
				}

				if (Array.isArray(source)) {
					for (const item of source) {
						if (item && typeof item === 'object') {
							const count = readNumberFromRecord(item, ['count', 'contributionCount', 'contributions']);
							if (typeof count === 'number') {
								counts.push(Math.max(0, count));
							}
						}
					}

					return counts;
				}

				const record = source;

				if (Array.isArray(record.weeks)) {
					for (const week of record.weeks) {
						if (!week || typeof week !== 'object') {
							continue;
						}

						const contributionDays = Array.isArray(week.contributionDays)
							? week.contributionDays
							: Array.isArray(week.contribution_days)
								? week.contribution_days
								: [];

						for (const day of contributionDays) {
							if (!day || typeof day !== 'object') {
								continue;
							}

							const count = readNumberFromRecord(day, ['contributionCount', 'count', 'contributions']);
							if (typeof count === 'number') {
								counts.push(Math.max(0, count));
							}
						}
					}
				}

				if (Array.isArray(record.contributions)) {
					counts.push(...extractDailyCounts(record.contributions));
				}

				if (Array.isArray(record.days)) {
					counts.push(...extractDailyCounts(record.days));
				}

				if (Array.isArray(record.data)) {
					counts.push(...extractDailyCounts(record.data));
				}

				return counts;
			}

			function extractMetrics(payload) {
				if (!payload || typeof payload !== 'object') {
					return null;
				}

				const record = payload;
				const explicitTotal = readNumberFromRecord(record, ['total', 'totalContributions', 'total_contributions', 'contributionCount']);
				const dailyCounts = extractDailyCounts(record);
				const totalFromDays = dailyCounts.reduce((sum, value) => sum + value, 0);
				const total = typeof explicitTotal === 'number' ? explicitTotal : totalFromDays;
				const activeDays = dailyCounts.filter((count) => count > 0).length;

				if (!Number.isFinite(total)) {
					return null;
				}

				return {
					total: Math.max(0, Math.round(total)),
					activeDays,
				};
			}

			function normalizeWeeks(payload) {
				if (!payload || typeof payload !== 'object' || !Array.isArray(payload.weeks)) {
					return [];
				}

				return payload.weeks.filter((week) => week && typeof week === 'object');
			}

			function resolvePalette(payload) {
				if (payload && typeof payload === 'object' && Array.isArray(payload.colors_full) && payload.colors_full.length >= 5) {
					return payload.colors_full;
				}

				if (payload && typeof payload === 'object' && Array.isArray(payload.colorsFull) && payload.colorsFull.length >= 5) {
					return payload.colorsFull;
				}

				return DEFAULT_COLORS;
			}

			async function fetchPlayer(username) {
				let response;
				try {
					response = await fetch(`/api/contributions/${encodeURIComponent(username)}`);
				} catch {
					return {
						ok: false,
						username,
						error: 'Network error while fetching player data.',
					};
				}

				let body = {};
				try {
					body = await response.json();
				} catch {
					body = {};
				}

				if (!response.ok) {
					const message = typeof body.error === 'string' ? body.error : `Request failed with status ${response.status}.`;
					const retryAfter = response.headers.get('Retry-After');
					return {
						ok: false,
						username,
						error: retryAfter ? `${message} Try again in ${retryAfter} seconds.` : message,
					};
				}

				const metrics = extractMetrics(body.data);
				if (!metrics) {
					return {
						ok: false,
						username,
						error: 'Could not read contribution metrics from API response.',
					};
				}

				return {
					ok: true,
					username: typeof body.username === 'string' ? body.username : username,
					stale: Boolean(body.stale),
					metrics,
					weeks: normalizeWeeks(body.data),
					palette: resolvePalette(body.data),
					from: typeof body.data?.from === 'string' ? body.data.from : null,
					to: typeof body.data?.to === 'string' ? body.data.to : null,
				};
			}

			function comparePlayers(first, second) {
				if (first.metrics.total > second.metrics.total) {
					return 1;
				}
				if (first.metrics.total < second.metrics.total) {
					return -1;
				}
				if (first.metrics.activeDays > second.metrics.activeDays) {
					return 1;
				}
				if (first.metrics.activeDays < second.metrics.activeDays) {
					return -1;
				}
				return 0;
			}

			function renderPlayerCard(player, title) {
				const card = document.createElement('article');
				card.className = 'player';

				const heading = document.createElement('h3');
				heading.textContent = `${title}: ${player.username}`;
				card.appendChild(heading);

				if (player.ok) {
					const meta = document.createElement('div');
					meta.className = 'meta';

					const total = document.createElement('p');
					total.textContent = `Total contributions: ${player.metrics.total}`;
					meta.appendChild(total);

					const range = document.createElement('p');
					range.textContent = player.from && player.to
						? `Date range: ${player.from} to ${player.to}`
						: 'Date range: unavailable';
					meta.appendChild(range);

					const days = document.createElement('p');
					days.textContent = `Active days: ${player.metrics.activeDays}`;
					meta.appendChild(days);

					if (player.stale) {
						const staleNote = document.createElement('p');
						staleNote.className = 'note';
						staleNote.textContent = 'Showing stale cached data.';
						meta.appendChild(staleNote);
					}

					card.appendChild(meta);

					const graph = document.createElement('div');
					graph.className = 'contribution-graph';

					for (const week of player.weeks) {
						const weekColumn = document.createElement('div');
						weekColumn.className = 'week-column';
						const daysInWeek = getContributionDays(week);

						for (let index = 0; index < 7; index += 1) {
							const day = daysInWeek[index] ?? { count: 0, level: 0 };
							const square = document.createElement('span');
							square.className = 'day-cell';
							const level = dayLevel(day);
							square.style.backgroundColor = player.palette[level] ?? DEFAULT_COLORS[level] ?? DEFAULT_COLORS[0];
							square.title = `${dayCount(day)} contributions`;
							weekColumn.appendChild(square);
						}

						graph.appendChild(weekColumn);
					}

					card.appendChild(graph);
				} else {
					const error = document.createElement('p');
					error.textContent = player.error;
					card.appendChild(error);
				}

				return card;
			}

			form.addEventListener('submit', async (event) => {
				event.preventDefault();

				const playerOne = playerOneInput.value.trim();
				const playerTwo = playerTwoInput.value.trim();

				clearResults();
				clearAllFieldErrors();

				let hasValidationError = false;

				if (!playerOne) {
					setFieldError(playerOneInput, playerOneError, 'Player 1 username is required.');
					hasValidationError = true;
				}

				if (!playerTwo) {
					setFieldError(playerTwoInput, playerTwoError, 'Player 2 username is required.');
					hasValidationError = true;
				}

				if (hasValidationError) {
					setStatus('Enter both usernames before starting a battle.', 'error');
					(!playerOne ? playerOneInput : playerTwoInput).focus();
					return;
				}

				if (playerOne.toLowerCase() === playerTwo.toLowerCase()) {
					setFieldError(playerOneInput, playerOneError, 'Choose two different usernames.');
					setFieldError(playerTwoInput, playerTwoError, 'Choose two different usernames.');
					setStatus('Choose two different usernames for the battle.', 'error');
					playerTwoInput.focus();
					return;
				}

				const playerOneValid = isValidUsername(playerOne);
				const playerTwoValid = isValidUsername(playerTwo);

				if (!playerOneValid || !playerTwoValid) {
					if (!playerOneValid) {
						setFieldError(playerOneInput, playerOneError, 'Use 1-39 letters, numbers, or hyphens.');
					}
					if (!playerTwoValid) {
						setFieldError(playerTwoInput, playerTwoError, 'Use 1-39 letters, numbers, or hyphens.');
					}
					setStatus('Usernames are invalid. They cannot start or end with a hyphen.', 'error');
					(!playerOneValid ? playerOneInput : playerTwoInput).focus();
					return;
				}

				battleButton.disabled = true;
				battleButton.textContent = 'Battling...';
				setStatus('Fetching contribution data...', 'loading');

				const [firstResult, secondResult] = await Promise.all([
					fetchPlayer(playerOne),
					fetchPlayer(playerTwo),
				]);

				resultsSection.hidden = false;
				playerOneSlot.appendChild(renderPlayerCard(firstResult, 'Player 1'));
				playerTwoSlot.appendChild(renderPlayerCard(secondResult, 'Player 2'));

				if (firstResult.ok && secondResult.ok) {
					const comparison = comparePlayers(firstResult, secondResult);
					if (comparison > 0) {
						battleSummary.textContent = `Winner: ${firstResult.username}`;
					} else if (comparison < 0) {
						battleSummary.textContent = `Winner: ${secondResult.username}`;
					} else {
						battleSummary.textContent = 'Tie: both players have equal total contributions and active days.';
					}

					setStatus('Battle complete.', 'success');
				} else if (!firstResult.ok && !secondResult.ok) {
					battleSummary.textContent = 'No winner yet.';
					setStatus('Both player requests failed. Check the errors below.', 'error');
				} else {
					const winner = firstResult.ok ? firstResult.username : secondResult.username;
					battleSummary.textContent = `Partial result: ${winner} data loaded.`;
					setStatus('One player request failed. Showing available data.', 'error');
				}

				battleButton.disabled = false;
				battleButton.textContent = 'Battle';
			});

			playerOneInput.addEventListener('input', () => {
				clearFieldError(playerOneInput, playerOneError);
			});

			playerTwoInput.addEventListener('input', () => {
				clearFieldError(playerTwoInput, playerTwoError);
			});

			for (const input of [playerOneInput, playerTwoInput]) {
				input.addEventListener('keydown', (event) => {
					if (event.key === 'Enter') {
						event.preventDefault();
						form.requestSubmit();
					}
				});
			}
		</script>
	</body>
</html>
